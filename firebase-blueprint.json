{
  "entities": {
    "WinGoIssue": {
      "title": "WinGoIssue",
      "description": "A single game issue record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "issue": { "type": "string" },
        "number": { "type": "number" },
        "color": { "type": "string", "enum": ["red", "green", "violet"] }
      },
      "required": ["id", "issue", "number", "color"]
    }
  },
  "firestore": {
    "/daily_history/{date}": {
      "schema": "DailyIssues",
      "description": "Daily issues document containing an array of issues"
    }
  }
}
